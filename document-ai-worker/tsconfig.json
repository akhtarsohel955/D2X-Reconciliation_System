{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",

    "experimentalDecorators": true,          // ✅ REQUIRED
    "emitDecoratorMetadata": true,           // ✅ REQUIRED

    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist"
  }
}
